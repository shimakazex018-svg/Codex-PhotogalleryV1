# Reference only. server.js reads process environment variables directly and does not load this file.
# Set these values in the launching shell, task scheduler, service manager, or deployment environment.
# Do not put real secrets, user-specific credentials, or production-only values in this tracked file.

# HTTP listener. These values document the current defaults and are not changed by V1.0.1.
PORT=48101
HOST=0.0.0.0

# Original user media. Keep outside Git and back it up independently.
PHOTOS_DIR=D:\media\photos

# Writable runtime state: SQLite, logs, generated thumbnails, carousel cache, and metadata cache.
DATA_DIR=D:\photo-gallery-data

# Optional generated-media overrides. Defaults are derived from DATA_DIR when omitted.
THUMBNAILS_DIR=D:\photo-gallery-data\video-thumbnails
HLS_DIR=D:\photo-gallery-data\hls

# Duplicate-image recycle target. Prefer the same volume as PHOTOS_DIR and test with disposable files.
TRASH_DIR=D:\media\recycle-bin

# Executable names may be replaced by absolute paths in the deployment environment.
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# Duplicate hashing batch size. Increase only after measuring CPU, memory, and disk I/O impact.
DUPLICATE_BATCH_SIZE=100

# Destructive remote access. Keep disabled unless explicitly intended and protected externally.
ALLOW_REMOTE_DELETE=0
