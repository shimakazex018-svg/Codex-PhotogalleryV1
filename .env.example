# Reference format only. server.js does not automatically load this file.
# Provide real values through the launching shell, scheduler, service manager, or deployment environment.

# HTTP listener
PORT=48101
HOST=0.0.0.0

# Original user media directory
PHOTOS_DIR=<your-media-folder>

# Writable SQLite, logs, metadata, and generated cache directory
DATA_DIR=<your-runtime-data-folder>

# Optional generated-media directory overrides
THUMBNAILS_DIR=<your-thumbnail-folder>
HLS_DIR=<your-hls-folder>
IMAGE_PREVIEW_DIR=<your-runtime-image-preview-folder>

# Runtime cache policy
ENABLE_IMAGE_THUMBNAIL_GENERATION=0
ENABLE_IMAGE_PREVIEW_GENERATION=1
IMAGE_PREVIEW_MAX_EDGE=768
IMAGE_PREVIEW_QUALITY=78
HLS_CACHE_EXPIRE_DAYS=7

# Development-only structured search timings; keep disabled in formal runtime
SEARCH_PERF_LOG=0
SEARCH_BACKEND_MODE=auto

# Duplicate-media recycle destination
TRASH_DIR=<your-recycle-folder>

# Media executables
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# Duplicate hashing batch size
DUPLICATE_BATCH_SIZE=100

# Keep disabled unless destructive remote access is explicitly protected
ALLOW_REMOTE_DELETE=0
REMOTE_ADMIN_ENABLED=0
REMOTE_ADMIN_CIDRS=lan:192.168.31.0/24,zerotier:192.168.192.0/24
REMOTE_ADMIN_ORIGINS=http://127.0.0.1:48102,http://localhost:48102,http://192.168.31.153:48102,http://192.168.192.1:48102
DAILY_INDEX_SCAN_ENABLED=0
DAILY_INDEX_SCAN_HOUR=4
DAILY_INDEX_SCAN_MINUTE=0
